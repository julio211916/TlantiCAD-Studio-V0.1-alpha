{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "claudeApiInput",
  "description": "Input schema for claude-api skill",
  "type": "object",
  "additionalProperties": true,
  "properties": {
    "operation": {
      "type": "string",
      "enum": ["single-call", "streaming", "tool-use", "agent-loop", "batch"],
      "description": "Type of API operation"
    },
    "model": {
      "type": "string",
      "description": "Claude model to use (default: claude-opus-4-6)"
    },
    "messages": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "role": { "type": "string" },
          "content": { "type": "string" }
        }
      },
      "description": "Conversation messages"
    },
    "maxTokens": {
      "type": "integer",
      "description": "Maximum tokens to generate",
      "default": 1024
    },
    "language": {
      "type": "string",
      "enum": ["python", "typescript", "go", "java", "ruby", "curl"],
      "description": "Programming language for implementation"
    }
  }
}
