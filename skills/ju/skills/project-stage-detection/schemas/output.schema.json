{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "title": "ProjectStageDetection Output",
  "description": "Structured output from project-stage-detection execution",
  "type": "object",
  "required": ["stage", "score", "confidence", "projectRoot", "timestamp"],
  "properties": {
    "stage": {
      "type": "string",
      "enum": ["new", "early", "mid", "mature"],
      "description": "Detected project maturity stage"
    },
    "score": {
      "type": "integer",
      "minimum": 0,
      "description": "Raw score from indicator evaluation"
    },
    "maxScore": {
      "type": "integer",
      "minimum": 1,
      "description": "Maximum possible score"
    },
    "confidence": {
      "type": "integer",
      "minimum": 0,
      "maximum": 100,
      "description": "Detection confidence as percentage (score/maxScore * 100)"
    },
    "projectRoot": {
      "type": "string",
      "description": "Absolute path to the analyzed project root"
    },
    "indicators": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "label", "present", "weight"],
        "properties": {
          "id": { "type": "string" },
          "label": { "type": "string" },
          "present": { "type": "boolean" },
          "weight": { "type": "integer" }
        }
      },
      "description": "Per-indicator evaluation results"
    },
    "missingIndicators": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Labels of indicators that are absent"
    },
    "recommendations": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Actionable recommendations based on detected stage"
    },
    "timestamp": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp of detection"
    }
  },
  "additionalProperties": false
}
