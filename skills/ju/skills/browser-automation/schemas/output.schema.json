{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "browserAutomationOutput",
  "type": "object",
  "additionalProperties": true,
  "properties": {
    "ok": {
      "type": "boolean"
    },
    "data": {
      "type": "object",
      "description": "Extracted data or action result"
    },
