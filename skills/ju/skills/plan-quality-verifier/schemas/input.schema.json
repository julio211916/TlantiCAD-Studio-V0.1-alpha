{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "title": "PlanQualityVerifier Input",
  "description": "Validated inputs for plan-quality-verifier execution",
  "type": "object",
  "required": ["planContent"],
  "properties": {
    "planContent": {
      "type": "string",
      "minLength": 1,
      "description": "The raw markdown content of the implementation plan to verify"
    },
    "threshold": {
      "type": "number",
      "minimum": 0,
      "maximum": 100,
      "default": 60,
      "description": "Minimum score (0-100) required for pass verdict. Defaults to 60."
    }
  },
  "additionalProperties": false
}
