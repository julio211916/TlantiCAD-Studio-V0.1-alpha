{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "cronDecisionInput",
  "description": "Input schema for cron-decision skill",
  "type": "object",
  "additionalProperties": true,
  "properties": {
    "taskDescription": {
      "type": "string",
      "description": "Description of the task to schedule"
    },
    "schedule": {
      "type": "string",
      "description": "Proposed cron schedule expression"
    },
    "requirements": {
      "type": "object",
      "description": "Scheduling requirements",
      "properties": {
        "mustSurviveSession": { "type": "boolean" },
        "precision": { "type": "string" },
        "isRecurring": { "type": "boolean" }
      }
    }
  }
}
